generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Car {
  id                       Int           @id @default(autoincrement())
  brand                    String
  model                    String
  registrationNumber       String        @unique
  year                     Int?
  fuelType                 String
  transmission             String
  dailyPrice               Float
  status                   String        @default("AVAILABLE")
  mileage                  Int?
  imageUrl                 String?
  insuranceExpiryDate      DateTime?
  technicalVisitExpiryDate DateTime?
  archived                 Boolean       @default(false)
  archivedAt               String?
  archivedReason           String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  reservations             Reservation[]
}

model Client {
  id                  Int           @id @default(autoincrement())
  fullName            String
  phone               String
  cin                 String?
  passportNumber      String?
  drivingLicense      String?
  drivingLicenseDate  String?
  cinIssueDate        String?
  cinIssuePlace       String?
  birthDate           String?
  birthPlace          String?
  nationality         String?
  address             String?
  isActive            Boolean       @default(true)
  archived            Boolean       @default(false)
  archivedAt          String?
  archivedReason      String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  reservations        Reservation[] @relation("PrimaryClientReservations")
  secondDriverReservations Reservation[] @relation("SecondClientReservations")

  @@unique([phone])
  @@unique([cin])
  @@unique([passportNumber])
  @@unique([drivingLicense])
}

model Reservation {
  id              Int       @id @default(autoincrement())
  clientId        Int
  secondClientId  Int?
  carId           Int
  startDate       DateTime
  endDate         DateTime
  dailyPrice      Float
  totalPrice      Float
  depositAmount   Float     @default(0)
  status          String    @default("RESERVED")
  pickupMileage   Int?
  returnMileage   Int?
  pickupFuelLevel String?
  returnFuelLevel String?
  notes           String?
  archived        Boolean   @default(false)
  archivedAt      String?
  archivedReason  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  client          Client    @relation("PrimaryClientReservations", fields: [clientId], references: [id])
  secondClient    Client?   @relation("SecondClientReservations", fields: [secondClientId], references: [id])
  car             Car       @relation(fields: [carId], references: [id])
  payments        Payment[]
  contract        Contract?
}

model Payment {
  id            Int         @id @default(autoincrement())
  reservationId Int
  amount        Float
  type          String
  method        String
  paymentDate   DateTime    @default(now())
  note          String?
  archived      Boolean     @default(false)
  archivedAt    String?
  archivedReason String?
  createdAt     DateTime    @default(now())
  reservation   Reservation @relation(fields: [reservationId], references: [id])
}

model Contract {
  id             Int         @id @default(autoincrement())
  reservationId  Int         @unique
  contractNumber String      @unique
  pdfPath        String?
  status         String      @default("GENERATED")
  generatedAt    DateTime    @default(now())
  signedAt       DateTime?
  archived       Boolean     @default(false)
  archivedAt     String?
  archivedReason String?
  createdAt      DateTime    @default(now())
  reservation    Reservation @relation(fields: [reservationId], references: [id])
}

model User {
  id           Int      @id @default(autoincrement())
  fullName     String
  username     String   @unique
  passwordSalt String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt  DateTime?
}
