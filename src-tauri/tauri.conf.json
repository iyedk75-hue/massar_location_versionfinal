{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Massar Location",
  "version": "0.1.0",
  "identifier": "com.rentaldesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Massar Location",
        "width": 1366,
        "height": 768,
        "minWidth": 1200,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
